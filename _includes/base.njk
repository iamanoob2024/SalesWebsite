<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — CAC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --cac-near-black:    #141414;
      --cac-ink:           #1F1F1F;
      --cac-surface-white: #F8F7F4;
      --cac-mid-grey:      #8A8A8A;
      --cac-light-grey:    #E2E0DC;
      --cac-cold-red:      #C0392B;
      --cac-system-blue:   #1A3A5C;
      --cac-font-editorial: 'Cormorant Garamond', Georgia, serif;
      --cac-font-mono:      'JetBrains Mono', 'Courier New', monospace;
      --cac-space-xs:  8px;
      --cac-space-sm:  16px;
      --cac-space-md:  32px;
      --cac-space-lg:  64px;
      --cac-space-xl:  120px;
      --cac-max-width: 1280px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--cac-near-black);
      color: var(--cac-surface-white);
      font-family: var(--cac-font-mono);
      font-size: 13px;
      font-weight: 300;
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ── NAV ── */
    .site-nav {
      border-bottom: 1px solid #1e1e1e;
      padding: var(--cac-space-sm) var(--cac-space-md);
      display: flex;
      gap: var(--cac-space-md);
      align-items: center;
      background: var(--cac-near-black);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .site-nav .logo { height: 36px; width: auto; margin-right: auto; }
    .site-nav a {
      color: var(--cac-mid-grey);
      text-decoration: none;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      transition: color 0.15s;
    }
    .site-nav a:hover { color: var(--cac-cold-red); }

    /* ── ARTICLE FRAME ── */
    .article-frame {
      display: grid;
      grid-template-columns: 1fr 1fr;
      height: calc(100vh - 57px);
      border: 1px solid #2a2a2a;
      margin: var(--cac-space-md);
      border-radius: 2px;
      overflow: hidden;
    }

    /* ── LEFT: VISUAL PANEL ── */
    .visual-panel {
      position: relative;
      background: #0e0e0e;
      border-right: 1px solid #2a2a2a;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .visual-panel img,
    .visual-panel video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }
    .visual-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: var(--cac-space-md);
      text-align: center;
      width: 100%;
      height: 100%;
    }
    .visual-placeholder-label {
      font-family: var(--cac-font-mono);
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--cac-cold-red);
    }
    .visual-placeholder-line {
      width: 40px;
      height: 1px;
      background: var(--cac-cold-red);
    }
    .visual-placeholder-note {
      font-family: var(--cac-font-mono);
      font-size: 10px;
      color: var(--cac-mid-grey);
      max-width: 240px;
      line-height: 1.7;
    }
    .visual-placeholder-code {
      font-family: var(--cac-font-mono);
      font-size: 10px;
      color: #444;
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      padding: 12px 16px;
      border-radius: 2px;
      text-align: left;
      width: 100%;
      max-width: 280px;
      line-height: 2;
    }
    .visual-placeholder-code span { color: var(--cac-cold-red); }

    /* ── RIGHT: TELEPROMPTER PANEL ── */
    .text-panel {
      position: relative;
      display: flex;
      flex-direction: column;
      background: var(--cac-near-black);
      overflow: hidden;
    }

    .text-panel-header {
      padding: var(--cac-space-md) var(--cac-space-md) var(--cac-space-sm);
      border-bottom: 1px solid #1e1e1e;
      flex-shrink: 0;
    }
    .article-label {
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--cac-cold-red);
      display: block;
      margin-bottom: 8px;
    }
    .article-title {
      font-family: var(--cac-font-editorial);
      font-size: clamp(20px, 2.5vw, 36px);
      font-weight: 300;
      letter-spacing: -0.01em;
      line-height: 1.15;
      color: var(--cac-surface-white);
    }

    /* Controls bar */
    .controls-bar {
      padding: 10px var(--cac-space-md);
      border-bottom: 1px solid #1e1e1e;
      display: flex;
      align-items: center;
      gap: var(--cac-space-sm);
      flex-shrink: 0;
    }
    .ctrl-btn {
      background: none;
      border: 1px solid #2a2a2a;
      color: var(--cac-mid-grey);
      font-family: var(--cac-font-mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 6px 12px;
      cursor: pointer;
      transition: all 0.15s;
      border-radius: 1px;
    }
    .ctrl-btn:hover { border-color: var(--cac-cold-red); color: var(--cac-cold-red); }
    .ctrl-btn.active { border-color: var(--cac-cold-red); color: var(--cac-cold-red); background: rgba(192,57,43,0.08); }
    .scroll-hint-text {
      font-size: 9px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #333;
      margin-left: auto;
      transition: color 0.3s;
    }
    .scroll-hint-text.visible { color: var(--cac-cold-red); }

    /* Teleprompter viewport */
    .teleprompter-viewport {
      flex: 1;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
      mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
    }
    .teleprompter-inner {
      position: absolute;
      width: 100%;
      padding: var(--cac-space-md);
      padding-bottom: var(--cac-space-xl);
    }
    .teleprompter-inner p {
      font-size: 14px;
      line-height: 1.95;
      color: var(--cac-mid-grey);
      margin-bottom: var(--cac-space-md);
    }
    .teleprompter-inner h2 {
      font-family: var(--cac-font-editorial);
      font-size: clamp(18px, 2vw, 26px);
      font-weight: 300;
      color: var(--cac-surface-white);
      margin: var(--cac-space-md) 0 var(--cac-space-sm);
      letter-spacing: -0.01em;
    }
    .teleprompter-inner a { color: var(--cac-cold-red); }

    /* Pause badge */
    .pause-badge {
      position: absolute;
      top: 12px;
      right: var(--cac-space-md);
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cac-cold-red);
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
      z-index: 10;
    }
    .paused .pause-badge { opacity: 1; }

    /* ── CTA BLOCK ── */
    .cta-strip {
      border-top: 1px solid #1e1e1e;
      padding: var(--cac-space-sm) var(--cac-space-md);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      gap: var(--cac-space-sm);
      flex-wrap: wrap;
    }
    .cta-btn {
      display: inline-block;
      background: var(--cac-cold-red);
      color: #fff;
      font-family: var(--cac-font-mono);
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      padding: 12px 24px;
      text-decoration: none;
      transition: opacity 0.15s;
      white-space: nowrap;
    }
    .cta-btn:hover { opacity: 0.85; }

    /* ── ARTICLE NAV ── */
    .article-nav {
      border-top: 1px solid #1e1e1e;
      padding: var(--cac-space-sm) var(--cac-space-md);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      gap: var(--cac-space-sm);
    }
    .article-nav a {
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cac-mid-grey);
      text-decoration: none;
      transition: color 0.15s;
      max-width: 200px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .article-nav a:hover { color: var(--cac-surface-white); }
    .article-nav .next-label { text-align: right; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .article-frame {
        grid-template-columns: 1fr;
        height: auto;
        margin: var(--cac-space-sm);
      }
      .visual-panel {
        height: 260px;
        border-right: none;
        border-bottom: 1px solid #2a2a2a;
      }
      .text-panel { height: 70vh; }
      .site-nav { padding: var(--cac-space-sm); }
    }
    @media (max-width: 480px) {
      .article-frame { margin: 8px; }
      .visual-panel { height: 200px; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="site-nav">
    <a href="/"><img src="/CAC_LOGO_2026_shadow.png" class="logo" alt="CAC"></a>
    <a href="/articles/">← Articles</a>
    <a href="/">Programme</a>
  </nav>

  <!-- ARTICLE FRAME -->
  <div class="article-frame">

    <!-- LEFT: VISUAL -->
    <div class="visual-panel" id="visual-panel">
      <!-- Populated by ARTICLE_CONFIG below -->
    </div>

    <!-- RIGHT: TEXT -->
    <div class="text-panel">

      <div class="text-panel-header">
        <span class="article-label">CAC — Article</span>
        <h1 class="article-title">{{ title }}</h1>
      </div>

      <div class="controls-bar">
        <button class="ctrl-btn" id="btn-pause">⏸ Pause</button>
        <button class="ctrl-btn" id="btn-speak">🔊 Read Aloud</button>
        <span class="scroll-hint-text" id="scroll-hint">Click to pause · Scroll to move</span>
      </div>

      <div class="teleprompter-viewport" id="teleprompter-viewport">
        <div class="pause-badge" id="pause-badge">⏸ Paused — scroll or click to resume</div>
        <div class="teleprompter-inner" id="teleprompter-inner">
          {{ content | safe }}
        </div>
      </div>

      <div class="cta-strip">
        <span style="font-size:10px;letter-spacing:0.1em;color:var(--cac-mid-grey);">Ready to change how you sell?</span>
        <a class="cta-btn" id="cta-link" href="#">Register for the Upcoming Training →</a>
      </div>

      <nav class="article-nav">
        <a href="/articles/" id="nav-back">← Back to Articles</a>
        {% if collections.all %}
          {% set currentIndex = 0 %}
          {% for item in collections.all %}
            {% if item.url == page.url %}{% set currentIndex = loop.index0 %}{% endif %}
          {% endfor %}
          {% if collections.all[currentIndex + 1] %}
            {% set nextArticle = collections.all[currentIndex + 1] %}
            <a href="{{ nextArticle.url }}" class="next-label">Next: {{ nextArticle.data.title | truncate(40) }} →</a>
          {% else %}
            <a href="/articles/" class="next-label">Back to all articles →</a>
          {% endif %}
        {% endif %}
      </nav>

    </div>
  </div>

<!-- ═══════════════════════════════════════════════════
     ARTICLE_CONFIG — edit everything here.
     Do NOT edit the HTML above.
════════════════════════════════════════════════════ -->
<script>
const ARTICLE_CONFIG = {

  // ── VISUAL (left panel) ─────────────────────────────
  // To use a still image: set type to "image" and put the filename in src
  //   e.g.  type: "{{ panel_type or "image" }}",  src: "my-photo.jpg"
  // To use a video:       set type to "video" and put the filename or URL in src
  //   e.g.  type: "video",  src: "https://www.youtube.com/embed/XXXXX"
  // Leave src as "" to show the placeholder until you have an asset.
  visual: {
    type: "{{ panel_type or "image" }}",   // "image" | "video" | ""
    src: "{{ panel_image }}",        // ← PUT YOUR IMAGE FILENAME OR VIDEO URL HERE
  },

  // ── CTA LINK ────────────────────────────────────────
  // Update this URL when your registration page is live.
  ctaUrl: "/register/",

  // ── TELEPROMPTER SPEED ──────────────────────────────
  // Pixels per second. Lower = slower. Default: 22
  scrollSpeed: 22,

  // ── RESUME AFTER PAUSE (milliseconds) ───────────────
  // How long after a click/gesture before auto-scroll resumes.
  resumeDelay: 3000,

};
</script>
<!-- ═══════════════════════════════════════════════════
     END ARTICLE_CONFIG
════════════════════════════════════════════════════ -->

<script>
(function () {

  // ── VISUAL PANEL ──────────────────────────────────
  const panel = document.getElementById('visual-panel');
  const v = ARTICLE_CONFIG.visual;

  if (v.src && v.type === 'image') {
    panel.innerHTML = `<img src="${v.src}" alt="">`;
  } else if (v.src && v.type === 'video') {
    panel.innerHTML = `<iframe src="${v.src}" frameborder="0" allowfullscreen
      style="width:100%;height:100%;border:none;"></iframe>`;
  } else {
    panel.innerHTML = `
      <div class="visual-placeholder">
        <div class="visual-placeholder-label">Visual Asset</div>
        <div class="visual-placeholder-line"></div>
        <div class="visual-placeholder-note">Add your image or video in ARTICLE_CONFIG below the HTML.</div>
        <div class="visual-placeholder-code">
          visual: {<br>
          &nbsp;&nbsp;type: <span>"image"</span>,<br>
          &nbsp;&nbsp;src: <span>"your-file.jpg"</span>,<br>
          }
        </div>
      </div>`;
  }

  // ── CTA LINK ──────────────────────────────────────
  document.getElementById('cta-link').href = ARTICLE_CONFIG.ctaUrl;

  // ── TELEPROMPTER ──────────────────────────────────
  const viewport = document.getElementById('teleprompter-viewport');
  const inner    = document.getElementById('teleprompter-inner');
  const badge    = document.getElementById('pause-badge');
  const btnPause = document.getElementById('btn-pause');
  const hint     = document.getElementById('scroll-hint');

  const SPEED  = ARTICLE_CONFIG.scrollSpeed;
  const RESUME = ARTICLE_CONFIG.resumeDelay;

  let pos      = 0;
  let paused   = false;
  let lastTime = null;
  let raf      = null;
  let resumeTimer = null;

  function contentH() { return inner.scrollHeight; }
  function viewH()    { return viewport.clientHeight; }

  // Start: text enters from bottom
  pos = viewH();
  inner.style.transform = `translateY(${pos}px)`;

  function setPaused(state) {
    paused = state;
    viewport.classList.toggle('paused', paused);
    btnPause.classList.toggle('active', paused);
    btnPause.textContent = paused ? '▶ Resume' : '⏸ Pause';
    if (paused) {
      hint.textContent = 'Scroll to move · Click or tap to resume';
      hint.classList.add('visible');
    } else {
      hint.textContent = 'Click to pause · Scroll to move';
      hint.classList.remove('visible');
      lastTime = null;
    }
  }

  function tick(timestamp) {
    if (!lastTime) lastTime = timestamp;
    const delta = (timestamp - lastTime) / 1000;
    lastTime = timestamp;

    if (!paused) {
      pos -= SPEED * delta;
      if (pos < -contentH()) pos = viewH(); // loop
      inner.style.transform = `translateY(${pos}px)`;
    }
    raf = requestAnimationFrame(tick);
  }
  raf = requestAnimationFrame(tick);

  // Click to pause/resume
  viewport.addEventListener('click', () => {
    setPaused(!paused);
    if (!paused) clearTimeout(resumeTimer);
  });

  // Pause button
  btnPause.addEventListener('click', (e) => {
    e.stopPropagation();
    setPaused(!paused);
    if (!paused) clearTimeout(resumeTimer);
  });

  // Scroll wheel: manual move + pause, auto-resume after RESUME ms
  viewport.addEventListener('wheel', (e) => {
    e.preventDefault();
    if (!paused) setPaused(true);

    pos -= e.deltaY * 0.8;
    const min = -contentH();
    const max = viewH();
    pos = Math.max(min, Math.min(max, pos));
    inner.style.transform = `translateY(${pos}px)`;

    clearTimeout(resumeTimer);
    resumeTimer = setTimeout(() => setPaused(false), RESUME);
  }, { passive: false });

  // Touch: swipe to scroll
  let touchStartY = null;
  viewport.addEventListener('touchstart', (e) => {
    touchStartY = e.touches[0].clientY;
    if (!paused) setPaused(true);
  }, { passive: true });

  viewport.addEventListener('touchmove', (e) => {
    if (touchStartY === null) return;
    const dy = touchStartY - e.touches[0].clientY;
    pos -= dy * 0.6;
    touchStartY = e.touches[0].clientY;
    const min = -contentH();
    const max = viewH();
    pos = Math.max(min, Math.min(max, pos));
    inner.style.transform = `translateY(${pos}px)`;

    clearTimeout(resumeTimer);
    resumeTimer = setTimeout(() => setPaused(false), RESUME);
  }, { passive: true });

  // Keyboard
  viewport.setAttribute('tabindex', '0');
  viewport.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); pos -= 60; }
    if (e.key === 'ArrowUp')   { e.preventDefault(); pos += 60; }
    if (e.key === ' ')         { e.preventDefault(); setPaused(!paused); }
    inner.style.transform = `translateY(${pos}px)`;
  });

  // ── READ ALOUD ────────────────────────────────────
  const btnSpeak = document.getElementById('btn-speak');
  let speaking = false;
  let utterance = null;

  btnSpeak.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!('speechSynthesis' in window)) {
      btnSpeak.textContent = '🔊 Not supported';
      return;
    }
    if (speaking) {
      window.speechSynthesis.cancel();
      speaking = false;
      btnSpeak.textContent = '🔊 Read Aloud';
      btnSpeak.classList.remove('active');
    } else {
      const text = inner.innerText;
      utterance = new SpeechSynthesisUtterance(text);
      utterance.rate = 0.92;
      utterance.onend = () => {
        speaking = false;
        btnSpeak.textContent = '🔊 Read Aloud';
        btnSpeak.classList.remove('active');
      };
      window.speechSynthesis.speak(utterance);
      speaking = true;
      btnSpeak.textContent = '🔊 Stop';
      btnSpeak.classList.add('active');
    }
  });

})();
</script>

</body>
</html>
