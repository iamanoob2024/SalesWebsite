---
layout: base.njk
title: Clarity Systems | Lovinia Mak
---
<style>
  :root {
    --bg: #050505;
    --text-dim: #333;
    --text-bright: #F8F7F4;
    --accent: #C0392B;
  }

  body { background: var(--bg); overflow-x: hidden; font-family: sans-serif; }

  /* 1. Text Transition: Reveal */
  .reveal-text {
    font-family: monospace;
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    background: linear-gradient(to right, var(--text-bright) 50%, var(--text-dim) 50%);
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: reveal 3s forwards cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes reveal {
    to { background-position: 0% 0; }
  }

  /* 2. Blueprint Section */
  .blueprint-text {
    font-family: serif;
    font-size: 1.2rem;
    color: var(--text-dim);
    border: 1px dashed #222;
    padding: 20px;
    display: inline-block;
    margin-bottom: 2rem;
  }

  /* 3. 3D Button */
  .btn-3d {
    appearance: none;
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 4px;
    color: var(--text-bright);
    cursor: pointer;
    font-family: monospace;
    font-size: 1rem;
    letter-spacing: 0.2em;
    padding: 16px 40px;
    position: relative;
    box-shadow: 0 6px 0 #000;
    transition: all 0.1s ease;
    text-transform: uppercase;
  }

  .btn-3d:active {
    box-shadow: 0 2px 0 #000;
    transform: translateY(4px);
  }

  /* 4. Card System */
  #card-grid {
    display: none; /* Hidden until Start Here is clicked */
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 4rem;
    width: 100%;
    max-width: 1000px;
  }

  .course-card {
    background: #0A0A0A;
    border: 1px solid #1A1A1A;
    padding: 30px;
    transition: border-color 0.3s ease;
    text-decoration: none;
  }

  .course-card:hover {
    border-color: var(--accent);
  }
</style>

<main style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; text-align: center;">
  
  <div class="reveal-text" style="margin-bottom: 4rem;">
    Welcome to ClaritySystems.work
  </div>

  <div style="margin-bottom: 2rem;">
    <div class="blueprint-text">
      Soft Skills Factory <br>
      <span style="font-size: 0.8rem; opacity: 0.6;">by Clarity Awareness Cognitive Architecture Systems</span>
    </div>
    
    <br>

    <button class="btn-3d" onclick="revealCards()">START HERE</button>
    
    <p style="margin-top: 1.5rem; font-family: serif; color: #555; font-size: 0.9rem; font-style: italic;">
      by Lovinia Mak
    </p>
  </div>

  <div id="card-grid">
    {% for item in navigation %}
    <a href="{{ item.url }}" class="course-card">
      <span style="color: var(--accent); font-family: monospace; font-size: 0.7rem;">{{ item.tag }}</span>
      <h3 style="color: var(--text-bright); font-family: serif; font-size: 1.5rem; margin: 15px 0;">{{ item.title }}</h3>
      <p style="color: #666; font-size: 0.9rem; line-height: 1.6;">{{ item.description }}</p>
    </a>
    {% endfor %}
  </div>

</main>

<script>
  function revealCards() {
    const grid = document.getElementById('card-grid');
    grid.style.display = 'grid';
    grid.scrollIntoView({ behavior: 'smooth' });
  }
</script>
