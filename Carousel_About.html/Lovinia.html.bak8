<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About Lovinia Mak — Clarity Awareness Cognitive Architecture Systems</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    /* ─── DESIGN TOKENS (match index.html exactly) ─── */
    :root {
      --cac-near-black:     #141414;
      --cac-ink:            #1F1F1F;
      --cac-surface-white:  #F8F7F4;
      --cac-mid-grey:       #8A8A8A;
      --cac-light-grey:     #E2E0DC;
      --cac-cold-red:       #C0392B;
      --cac-system-blue:    #1A3A5C;
      --cac-font-editorial: 'Cormorant Garamond', Georgia, serif;
      --cac-font-mono:      'JetBrains Mono', 'Courier New', monospace;
      --cac-space-xs:   8px;
      --cac-space-sm:   16px;
      --cac-space-md:   32px;
      --cac-space-lg:   64px;
      --cac-space-xl:   120px;
      --cac-max-width:  1280px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--cac-surface-white);
      color: var(--cac-ink);
      font-family: var(--cac-font-mono);
      font-size: 13px;
      font-weight: 300;
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── TYPE SCALE ─── */
    .t1 { font-family: var(--cac-font-editorial); font-size: clamp(48px, 8vw, 96px); font-weight: 300; letter-spacing: -0.02em; line-height: 1.0; }
    .t2 { font-family: var(--cac-font-editorial); font-size: clamp(28px, 4vw, 52px); font-weight: 300; letter-spacing: -0.01em; line-height: 1.1; }
    .t4 { font-family: var(--cac-font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.22em; line-height: 1.6; text-transform: uppercase; }
    .t5 { font-family: var(--cac-font-mono); font-size: 13px; font-weight: 300; line-height: 1.8; }
    .t6 { font-family: var(--cac-font-mono); font-size: 11px; font-weight: 300; line-height: 1.6; color: var(--cac-mid-grey); }

    /* ─── NAV ─── */
    .site-nav {
      background: var(--cac-near-black);
      padding: var(--cac-space-md) var(--cac-space-xl);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #1e1e1e;
    }
    .nav-logo {
      font-family: var(--cac-font-editorial);
      color: var(--cac-surface-white);
      font-size: 15px;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      line-height: 1.4;
      text-decoration: none;
    }
    .nav-logo span {
      display: block;
      font-family: var(--cac-font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      color: var(--cac-mid-grey);
      margin-top: 4px;
      text-transform: uppercase;
    }
    .nav-back {
      font-family: var(--cac-font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cac-mid-grey);
      text-decoration: none;
      transition: color 0.15s;
    }
    .nav-back:hover { color: var(--cac-cold-red); }

    /* ─── SECTIONS ─── */
    section { padding: var(--cac-space-lg) 0; }
    section + section { border-top: 1px solid var(--cac-light-grey); }
    .container { max-width: var(--cac-max-width); margin: 0 auto; padding: 0 var(--cac-space-xl); }

    /* ─── TWO-COL GRID ─── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--cac-space-lg);
      align-items: flex-start;
    }

    /* ─── SECTION LABELS ─── */
    .section-label {
      display: block;
      color: var(--cac-cold-red);
      margin-bottom: var(--cac-space-md);
    }

    /* ─── IMAGE FRAME ─── */
    .image-frame {
      position: relative;
      width: 100%;
      height: 800px;
      border: 1px solid var(--cac-light-grey);
      background: #222;
      overflow: hidden;
    }
    .image-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
    }
    /* Placeholder shown when no image src is set */
    .image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      color: var(--cac-mid-grey);
      font-family: var(--cac-font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-align: center;
      padding: 24px;
    }
    .image-placeholder-label {
      color: var(--cac-cold-red);
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    /* ─── TELEPROMPTER ─── */
    .teleprompter-wrap {
      position: relative;
      height: 420px;
      overflow: hidden;
      cursor: pointer;
      border-left: 2px solid var(--cac-light-grey);
      padding-left: var(--cac-space-md);
      /* Fade top and bottom edges */
      -webkit-mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        black 12%,
        black 88%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        black 12%,
        black 88%,
        transparent 100%
      );
    }

    .teleprompter-inner {
      position: absolute;
      width: 100%;
      /* animation applied via JS */
    }

    .teleprompter-inner p {
      font-size: 14px;
      line-height: 1.9;
      color: var(--cac-mid-grey);
      margin-bottom: var(--cac-space-md);
    }

    /* Controls: click = pause/play, scroll wheel = manual */
    .scroll-hint {
      position: absolute;
      bottom: 0;
      left: var(--cac-space-md);
      right: 0;
      display: flex;
      align-items: center;
      gap: var(--cac-space-sm);
      padding: var(--cac-space-sm) 0;
      z-index: 10;
      pointer-events: none;
    }
    .scroll-hint span {
      font-family: var(--cac-font-mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cac-cold-red);
      opacity: 0;
      transition: opacity 0.4s;
    }
    .teleprompter-wrap:hover .scroll-hint span { opacity: 1; }

    /* Pause indicator */
    .pause-badge {
      position: absolute;
      top: var(--cac-space-sm);
      right: 0;
      font-family: var(--cac-font-mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cac-cold-red);
      opacity: 0;
      transition: opacity 0.3s;
      z-index: 10;
      pointer-events: none;
    }
    .teleprompter-wrap.paused .pause-badge { opacity: 1; }

    /* ─── CREDENTIALS ─── */
    .cred-list {
      list-style: none;
      margin-top: var(--cac-space-md);
      border-top: 1px solid var(--cac-light-grey);
      padding-top: var(--cac-space-md);
    }
    .cred-list li {
      display: flex;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid var(--cac-light-grey);
      font-size: 12px;
      color: var(--cac-mid-grey);
      line-height: 1.6;
    }
    .cred-list li:last-child { border-bottom: none; }
    .cred-dash { color: var(--cac-cold-red); flex-shrink: 0; }

    /* ─── STRUCTURE BLOCK ─── */
    #structure { background: var(--cac-surface-white); }
    .structure-quote {
      font-family: var(--cac-font-editorial);
      font-size: clamp(20px, 2.5vw, 28px);
      font-weight: 300;
      line-height: 1.4;
      color: var(--cac-ink);
      margin-bottom: var(--cac-space-md);
      max-width: 600px;
    }
    .structure-body {
      font-size: 13px;
      line-height: 1.9;
      color: var(--cac-mid-grey);
      max-width: 560px;
    }

    /* ─── STRUCTURE IMAGE FRAME ─── */
    .image-frame-light {
      position: relative;
      width: 100%;
      height: 560px;
      border: 1px solid var(--cac-light-grey);
      background: #f0efec;
      overflow: hidden;
    }
    .image-frame-light img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ─── EVENT BAR ─── */
    .event-bar {
      background: var(--cac-near-black);
      border-top: 1px solid #1e1e1e;
      padding: var(--cac-space-md) var(--cac-space-xl);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--cac-space-md);
    }
    .event-bar-label {
      display: block;
      font-family: var(--cac-font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cac-mid-grey);
      margin-bottom: 5px;
    }
    .event-bar-value {
      font-family: var(--cac-font-editorial);
      font-size: 15px;
      font-weight: 300;
      color: var(--cac-surface-white);
    }

    /* ─── FOOTER ─── */
    footer {
      background: var(--cac-near-black);
      border-top: 1px solid #1a1a1a;
      padding: var(--cac-space-md) var(--cac-space-xl);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      :root { --cac-space-xl: 32px; --cac-space-lg: 48px; }
      .site-nav { padding: var(--cac-space-sm) 24px; }
      .two-col { grid-template-columns: 1fr; }
      .image-frame { height: 400px; }
      .image-frame-light { height: 360px; }
      .teleprompter-wrap { height: 360px; }
      .event-bar { grid-template-columns: 1fr 1fr; padding: var(--cac-space-md) 24px; }
      footer { padding: var(--cac-space-md) 24px; flex-direction: column; gap: 10px; }
    }
    @media (max-width: 480px) {
      .event-bar { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════
     SITE_CONFIG — swap all content and image paths here.
     Never edit the HTML below unless changing structure.
════════════════════════════════════════════════════ -->
<script>
const SITE_CONFIG = {

  // ── 01 INTRO ──────────────────────────────────────────
  intro: {
    label: "01 — About Your Trainer",
    name:  "Lovinia Mak",

    // Scrolling narrative paragraphs — add/edit/remove freely
    paragraphs: [
      "Build fast, learn faster — but the foundational structure must be there for anything to be sustainable long-term and worthy of trust.",
      "Lovinia Mak was the founder of ESL.Connection. She has a Level 7 graduate diploma in teaching. She taught levelled-reading and writing for K–12 and Workplace English for adults. She also developed O.L.I.V.E (Online Learning Integrated Virtual Environment) on Moodle.",
      "Separately, she created English Through Art, a Reggio-Emilia inspired right-brain approach that lowers the affect barrier for children in second language learning.",
      "Lovinia is also the founder of Clarity Awareness Coaching — now Clarity Awareness Cognitive Architecture Systems. CAC focuses on the intersections that cause the experience of 'feeling stuck' in a transformation, in communication, or in sales. Lovinia is a certified practitioner of EFT (Emotional Freedom Technique) and incorporates EFT in private coaching and consultative work.",
      "Prior to teaching, Lovinia was in Advertising, Market Research, Sales, Corporate Communications, and Content Editing — having worked with companies including AC Nielsen Media, Market Behaviour London, Technology Park Malaysia, and Asia E-Golf (a subsidiary of IREKA).",
      "Lovinia's first non-fiction book, The Structureless Potential, is scheduled to be published in 2026."
    ],

    // Scroll speed — pixels per second. Lower = slower.
    scrollSpeed: 28,

    // SWAP IMAGE: replace "" with the path to your photo, e.g. "images/lovinia.jpg"
    // Leave as "" to show the placeholder.
    image: "image_1.jpg",
    imagePlaceholderLabel: "Photo — Lovinia Mak",
    imagePlaceholderNote:  "Replace intro.image in SITE_CONFIG with your image path"
  },

  // ── 02 STRUCTURE ──────────────────────────────────────
  structure: {
    label: "02 — Philosophy",
    // Opening statement rendered large
    pullQuote: "Simple is not the same thing as easy.",
    // Body paragraphs
    paragraphs: [
      "Lovinia's philosophy is that human problems are solvable in the same way business and engineering problems are solvable.",
      "What is required is asking the right questions at the right level, and having enough data and cross-domain knowledge to see the substrate layer underneath a given application. The end user never needs to know everything about the materials sciences and physics behind a given thing. They need just enough to deconstruct complexity and construct something usable and meaningful within a given scope.",
      "The linchpin is the human ability to articulate a vision or idea — to transmit it with precision, whether in notation, drawings, or language."
    ],

    // SWAP IMAGE: replace "block_2.png" with your second image path, e.g. "images/structure.jpg"
    // Leave as "" to show the placeholder.
    image: "block_2.png",
    imagePlaceholderLabel: "Image — Structure Block",
    imagePlaceholderNote:  "Replace structure.image in SITE_CONFIG with your image path"
  },

  // ── CREDENTIALS ───────────────────────────────────────
  // Add, remove, or edit entries freely.
  credentials: [
    "Founder, Clarity Awareness Cognitive Architecture Systems",
    "Principal Trainer, Sales For Technical And Non-Sales Professionals",
    "Author, <em>The Structureless Potential</em> (scheduled, 2026)",
    "Creator, Buying Psychology Profiling System",
    "Creator, 4E Framework for Sales Conversations That Land",

  ],

  // ── FOOTER LINKS ──────────────────────────────────────
  social: {
    facebook: "https://facebook.com/clarityawarenesscoaching",
    linkedin: "https://linkedin.com/in/loviniamak"
  }

};
</script>
<!-- ═══════════════════════════════════════════════════
     END SITE_CONFIG
════════════════════════════════════════════════════ -->


<!-- NAV -->
<nav class="site-nav">
  <a href="/" class="nav-logo">
    Clarity Awareness
    <span>Cognitive Architecture Systems</span>
  </a>
  <a href="/" class="nav-back">← Back to Programme</a>
</nav>


<!-- 01 INTRO -->
<section id="intro" style="background: var(--cac-near-black);">
  <div class="container">
    <div class="two-col">

      <!-- LEFT: Image -->
      <div>
        <div class="image-frame" id="intro-image-frame">
          <!-- Populated by JS -->
        </div>
      </div>

      <!-- RIGHT: Teleprompter -->
      <div>
        <span class="t4 section-label" id="intro-label" style="color: var(--cac-cold-red);"></span>
        <h1 class="t1" id="intro-name" style="color: var(--cac-surface-white); margin-bottom: var(--cac-space-md);"></h1>

        <div class="teleprompter-wrap" id="teleprompter"
             title="Click to pause · Scroll to move manually">
          <div class="teleprompter-inner" id="teleprompter-inner">
            <!-- Paragraphs injected by JS -->
          </div>
          <div class="pause-badge" id="pause-badge">⏸ Paused — scroll or click to resume</div>
          <div class="scroll-hint">
            <span>Click to pause · Scroll to move</span>
          </div>
        </div>

        <!-- Credentials -->
        <div style="margin-top: var(--cac-space-lg);">
          <span class="t4" style="color: var(--cac-mid-grey);">Credentials</span>
          <ul class="cred-list" id="cred-list">
            <!-- Injected by JS -->
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- 02 STRUCTURE / PHILOSOPHY -->
<section id="structure">
  <div class="container">
    <div class="two-col">

      <!-- LEFT: Text -->
      <div>
        <span class="t4 section-label" id="structure-label" style="color: var(--cac-cold-red);"></span>
<div class="teleprompter-wrap" id="teleprompter2" title="Hold to pause · Scroll to move">
<div class="teleprompter-inner" id="structure-inner"></div>
<div class="pause-badge" id="pause-badge2">⏸ Paused</div>
</div>      <!-- RIGHT: Image -->
      <div>
        <div class="image-frame-light" id="structure-image-frame">
          <!-- Populated by JS -->
        </div>
      </div>

    </div>
  </div>
</section>


<!-- EVENT BAR -->
<div class="event-bar">
  <div>
    <span class="event-bar-label">Programme</span>
    <div class="event-bar-value">
      <a href="/" style="color:var(--cac-surface-white);text-decoration:none;">← Sales Programme</a>
    </div>
  </div>
  <div>
    <span class="event-bar-label">Read More</span>
    <div class="event-bar-value">
      <a href="/articles/" style="color:var(--cac-surface-white);text-decoration:none;">Articles →</a>
    </div>
  </div>
  <div>
    <span class="event-bar-label">Register</span>
    <div class="event-bar-value">
      <a href="/register/" style="color:var(--cac-surface-white);text-decoration:none;">Register Now →</a>
    </div>
  </div>
  <div>
    <span class="event-bar-label">Follow</span>
    <div style="display:flex;flex-direction:column;gap:6px;margin-top:4px;">
      <a id="fb-link" href="#" target="_blank"
         style="color:var(--cac-surface-white);font-family:var(--cac-font-mono);font-size:11px;text-decoration:none;letter-spacing:0.08em;">Facebook →</a>
      <a id="li-link" href="#" target="_blank"
         style="color:var(--cac-surface-white);font-family:var(--cac-font-mono);font-size:11px;text-decoration:none;letter-spacing:0.08em;">LinkedIn →</a>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="t6">Clarity Awareness Cognitive Architecture Systems</div>
  <div class="t6">
    <a href="/" style="color:var(--cac-mid-grey);text-decoration:none;margin-right:32px;">Programme</a>
    <a href="/privacy-policy.html" style="color:var(--cac-mid-grey);text-decoration:none;">Privacy Policy</a>
  </div>
  <div class="t6">v1.0</div>
</footer>


<script>
// ─── RENDER FROM CONFIG ───────────────────────────────────────────────────────

function renderPage() {
  const { intro, structure, credentials, social } = SITE_CONFIG;

  // Social links
  document.getElementById('fb-link').href = social.facebook;
  document.getElementById('li-link').href = social.linkedin;

  // ── INTRO ──
  document.getElementById('intro-label').textContent = intro.label;
  document.getElementById('intro-name').textContent  = intro.name;

  // Image or placeholder
  const introFrame = document.getElementById('intro-image-frame');
  if (intro.image) {
    introFrame.innerHTML = `<img src="${intro.image}" alt="${intro.name}">`;
  } else {
    introFrame.innerHTML = `
      <div class="image-placeholder">
        <div class="image-placeholder-label">${intro.imagePlaceholderLabel}</div>
        <div style="width:48px;height:1px;background:var(--cac-cold-red);margin:8px auto;"></div>
        <div>${intro.imagePlaceholderNote}</div>
      </div>`;
  }

  // Teleprompter paragraphs
  document.getElementById('teleprompter-inner').innerHTML =
    intro.paragraphs.map(p => `<p>${p}</p>`).join('');

  // Credentials
  document.getElementById('cred-list').innerHTML =
    credentials.map(c => `
      <li><span class="cred-dash">—</span><span>${c}</span></li>
    `).join('');

  // ── STRUCTURE ──
  document.getElementById('structure-label').textContent     = structure.label;
  document.getElementById('structure-pullquote').textContent = structure.pullQuote;
  const strFrame = document.getElementById('structure-image-frame');
  if (structure.image) {
    strFrame.innerHTML = `<img src="${structure.image}" alt="Structure">`;
  } else {
    strFrame.innerHTML = `
      <div class="image-placeholder" style="background:#f0efec;">
        <div class="image-placeholder-label">${structure.imagePlaceholderLabel}</div>
        <div style="width:48px;height:1px;background:var(--cac-cold-red);margin:8px auto;"></div>
        <div>${structure.imagePlaceholderNote}</div>
      </div>`;
  }
}

renderPage();


// ─── TELEPROMPTER ENGINE ──────────────────────────────────────────────────────

(function () {
  const wrap   = document.getElementById('teleprompter');
  const inner  = document.getElementById('teleprompter-inner');
  const badge  = document.getElementById('pause-badge');

  const SPEED  = SITE_CONFIG.intro.scrollSpeed; // px/second
  let pos      = 0;       // current translateY offset (negative = scrolled up)
  let paused   = false;
  let lastTime = null;
  let raf      = null;

  // Content height and viewport height
  function contentH() { return inner.scrollHeight; }
  function viewH()    { return wrap.clientHeight; }

  // Start from just below the bottom of the viewport
  pos = viewH();
  inner.style.transform = `translateY(${pos}px)`;

  function tick(timestamp) {
    if (!lastTime) lastTime = timestamp;
    const delta = (timestamp - lastTime) / 1000; // seconds
    lastTime = timestamp;

    if (!paused) {
      pos -= SPEED * delta;
      // Loop: when text has fully scrolled past top, reset to bottom
      if (pos < -contentH()) {
        pos = viewH();
      }
      inner.style.transform = `translateY(${pos}px)`;
    }

    raf = requestAnimationFrame(tick);
  }

  raf = requestAnimationFrame(tick);


// ── PRESS: pause while held, resume on release ──
wrap.addEventListener("mousedown", () => { paused = true; wrap.classList.add("paused"); });
wrap.addEventListener("mouseup",   () => { paused = false; wrap.classList.remove("paused"); lastTime = null; });
wrap.addEventListener("touchstart", () => { paused = true; wrap.classList.add("paused"); }, { passive: true });
wrap.addEventListener("touchend",   () => { paused = false; wrap.classList.remove("paused"); lastTime = null; });
  // ── SCROLL WHEEL: manual movement ──
  wrap.addEventListener('wheel', (e) => {
    e.preventDefault();
    // Pause while scrolling manually
    if (!paused) {
      paused = true;
      wrap.classList.add('paused');
    }
    pos -= e.deltaY * 0.8;
    // Clamp: don't go above content top or below viewport bottom
    const min = -contentH();
    const max = viewH();
    pos = Math.max(min, Math.min(max, pos));
    inner.style.transform = `translateY(${pos}px)`;
  }, { passive: false });

  // ── KEYBOARD: arrow keys when focused ──
  wrap.setAttribute('tabindex', '0');
  wrap.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); pos -= 40; }
    if (e.key === 'ArrowUp')   { e.preventDefault(); pos += 40; }
    if (e.key === ' ')         { e.preventDefault(); paused = !paused; wrap.classList.toggle('paused', paused); }
    inner.style.transform = `translateY(${pos}px)`;
  });

  // Auto-resume after 8 seconds of no scroll interaction
  let resumeTimer = null;
  wrap.addEventListener('wheel', () => {
    clearTimeout(resumeTimer);
    resumeTimer = setTimeout(() => {
      if (paused) {
        paused = false;
        wrap.classList.remove('paused');
        lastTime = null;
      }
    }, 8000);
  });

})();
</script>

</body>
</html>
